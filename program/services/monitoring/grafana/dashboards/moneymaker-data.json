{
  "uid": "moneymaker-data",
  "title": "MONEYMAKER V1 - Data Pipeline",
  "description": "Data ingestion monitoring: ticks, bars, quality, latency, and pipeline health",
  "tags": ["moneymaker", "data", "ingestion"],
  "timezone": "utc",
  "editable": true,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "15s", "30s", "1m", "5m"]
  },
  "links": [
    {
      "title": "MONEYMAKER Overview",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/moneymaker-overview/moneymaker-v1-overview",
      "tooltip": "Navigate to MONEYMAKER Overview dashboard",
      "keepTime": true,
      "includeVars": true,
      "targetBlank": false
    },
    {
      "title": "MONEYMAKER Trading",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/moneymaker-trading/moneymaker-v1-trading",
      "tooltip": "Navigate to MONEYMAKER Trading dashboard",
      "keepTime": true,
      "includeVars": true,
      "targetBlank": false
    },
    {
      "title": "MONEYMAKER Risk",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/moneymaker-risk/moneymaker-v1-risk",
      "tooltip": "Navigate to MONEYMAKER Risk dashboard",
      "keepTime": true,
      "includeVars": true,
      "targetBlank": false
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "iconColor": "purple",
        "expr": "changes(moneymaker_build_info[1m]) > 0",
        "titleFormat": "Deployment",
        "tagKeys": "version,service",
        "textFormat": "{{service}} deployed version {{version}}",
        "step": "60s",
        "type": "tags"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "symbol",
        "label": "Symbol",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(moneymaker_ingestion_ticks_received_total, symbol)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "sort": 1
      },
      {
        "type": "query",
        "name": "exchange",
        "label": "Exchange",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(moneymaker_ingestion_ticks_received_total, exchange)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "sort": 1
      },
      {
        "type": "custom",
        "name": "timeframe",
        "label": "Timeframe",
        "query": "M1,M5,M15,M30,H1,H4,D1",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "M1", "value": "M1" },
          { "selected": false, "text": "M5", "value": "M5" },
          { "selected": false, "text": "M15", "value": "M15" },
          { "selected": false, "text": "M30", "value": "M30" },
          { "selected": false, "text": "H1", "value": "H1" },
          { "selected": false, "text": "H4", "value": "H4" },
          { "selected": false, "text": "D1", "value": "D1" }
        ]
      },
      {
        "type": "interval",
        "name": "interval",
        "label": "Interval",
        "query": "30s,1m,5m,15m,1h",
        "auto": true,
        "auto_count": 30,
        "auto_min": "10s",
        "options": [
          { "selected": false, "text": "30s", "value": "30s" },
          { "selected": false, "text": "1m", "value": "1m" },
          { "selected": true, "text": "5m", "value": "5m" },
          { "selected": false, "text": "15m", "value": "15m" },
          { "selected": false, "text": "1h", "value": "1h" }
        ],
        "current": { "selected": true, "text": "5m", "value": "5m" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "PIPELINE STATUS",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "title": "Ticks/s",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_ingestion_ticks_received_total[5m]))",
          "legendFormat": "Ticks/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "yellow" },
              { "value": 10, "color": "green" }
            ]
          },
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 3,
      "title": "Bars/s",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_ingestion_bars_completed_total[5m]))",
          "legendFormat": "Bars/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.1, "color": "green" }
            ]
          },
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 4,
      "title": "Data Quality Rejections 6h",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(moneymaker_brain_data_quality_rejected_total[6h]))",
          "legendFormat": "Rejected",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 50, "color": "red" }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 5,
      "title": "Ingestion Latency p95",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(moneymaker_ingestion_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.05, "color": "yellow" },
              { "value": 0.2, "color": "red" }
            ]
          },
          "decimals": 4
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 6,
      "title": "Pipeline Health",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(sum(rate(moneymaker_ingestion_ticks_received_total{exchange=~\"$exchange\"}[$interval])) > 0) * (histogram_quantile(0.95, sum(rate(moneymaker_ingestion_latency_seconds_bucket{exchange=~\"$exchange\"}[$interval])) by (le)) < 0.2) * 100",
          "legendFormat": "Pipeline Health",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DEGRADED", "color": "red", "index": 0 },
                "100": { "text": "HEALTHY", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 7,
      "title": "Throughput MB/s",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_ingestion_bytes_received_total{exchange=~\"$exchange\"}[$interval])) / 1024 / 1024",
          "legendFormat": "Throughput",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "MBs",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 8,
      "title": "INGESTION METRICS",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "panels": []
    },
    {
      "id": 9,
      "title": "Ticks Received per Symbol",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_ingestion_ticks_received_total{symbol=~\"$symbol\",exchange=~\"$exchange\"}[$interval])) by (symbol)",
          "legendFormat": "{{symbol}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 10,
      "title": "Ticks Received per Exchange",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_ingestion_ticks_received_total{symbol=~\"$symbol\",exchange=~\"$exchange\"}[$interval])) by (exchange)",
          "legendFormat": "{{exchange}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 11,
      "title": "Bars Completed per Symbol & Timeframe",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_ingestion_bars_completed_total{symbol=~\"$symbol\",timeframe=~\"$timeframe\"}[$interval])) by (symbol, timeframe)",
          "legendFormat": "{{symbol}} ({{timeframe}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"] }
      }
    },
    {
      "id": 12,
      "title": "Data Quality Rejections Over Time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_brain_data_quality_rejected_total[5m])) by (symbol, reason)",
          "legendFormat": "{{symbol}} - {{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.1, "color": "yellow" },
              { "value": 1, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "sum"] }
      }
    },
    {
      "id": 13,
      "title": "QUALITY & LATENCY",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "panels": []
    },
    {
      "id": 14,
      "title": "Ingestion Latency by Exchange p50/p95",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(moneymaker_ingestion_latency_seconds_bucket[5m])) by (exchange, le))",
          "legendFormat": "{{exchange}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(moneymaker_ingestion_latency_seconds_bucket[5m])) by (exchange, le))",
          "legendFormat": "{{exchange}} p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.05, "color": "yellow" },
              { "value": 0.2, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 15,
      "title": "Data Quality Rejection Reasons",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(moneymaker_brain_data_quality_rejected_total[6h])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      }
    },
    {
      "id": 16,
      "title": "Data Quality Score",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (clamp_max(sum(rate(moneymaker_brain_data_quality_rejected_total{symbol=~\"$symbol\"}[$interval])) / sum(rate(moneymaker_ingestion_ticks_received_total{symbol=~\"$symbol\"}[$interval])) * 100, 100))",
          "legendFormat": "Quality Score",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 90, "color": "orange" },
              { "value": 95, "color": "yellow" },
              { "value": 99, "color": "green" }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },
    {
      "id": 17,
      "title": "Latency vs Tick Rate Correlation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(moneymaker_ingestion_latency_seconds_bucket{exchange=~\"$exchange\"}[$interval])) by (le)) * 1000",
          "legendFormat": "Latency p95 (ms)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(moneymaker_ingestion_ticks_received_total{exchange=~\"$exchange\"}[$interval]))",
          "legendFormat": "Tick Rate (ticks/s)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 0,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "axisPlacement": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Latency p95 (ms)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "left" },
              { "id": "unit", "value": "ms" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Tick Rate (ticks/s)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "ops" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 18,
      "title": "Gap Detection Missing Bars",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_ingestion_bars_gap_detected_total{symbol=~\"$symbol\",timeframe=~\"$timeframe\"}[$interval])) by (symbol, timeframe)",
          "legendFormat": "{{symbol}} ({{timeframe}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.1, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] }
      }
    },
    {
      "id": 19,
      "title": "DATA HEALTH",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "panels": []
    },
    {
      "id": 20,
      "title": "Data Completeness by Symbol",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - (sum(increase(moneymaker_brain_data_quality_rejected_total{symbol=~\"$symbol\"}[1h])) by (symbol) / sum(increase(moneymaker_ingestion_ticks_received_total{symbol=~\"$symbol\"}[1h])) by (symbol))) * 100",
          "legendFormat": "{{symbol}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 95, "color": "yellow" },
              { "value": 99, "color": "green" }
            ]
          },
          "decimals": 2,
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal"
      }
    },
    {
      "id": 21,
      "title": "Exchange Reliability Score",
      "type": "table",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_ingestion_ticks_received_total{exchange=~\"$exchange\"}[$interval])) by (exchange)",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(moneymaker_ingestion_latency_seconds_bucket{exchange=~\"$exchange\"}[$interval])) by (exchange, le)) * 1000",
          "legendFormat": "",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "(1 - (sum(rate(moneymaker_brain_data_quality_rejected_total{exchange=~\"$exchange\"}[$interval])) by (exchange) / sum(rate(moneymaker_ingestion_ticks_received_total{exchange=~\"$exchange\"}[$interval])) by (exchange))) * 100",
          "legendFormat": "",
          "refId": "C",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "indexByName": { "exchange": 0, "Value #A": 1, "Value #B": 2, "Value #C": 3 },
            "renameByName": {
              "exchange": "Exchange",
              "Value #A": "Tick Rate (t/s)",
              "Value #B": "Latency p95 (ms)",
              "Value #C": "Quality %"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Tick Rate (t/s)" },
            "properties": [
              { "id": "unit", "value": "ops" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "yellow" }, { "value": 10, "color": "green" }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Latency p95 (ms)" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 50, "color": "yellow" }, { "value": 200, "color": "red" }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Quality %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 95, "color": "yellow" }, { "value": 99, "color": "green" }] } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false },
        "sortBy": [{ "displayName": "Quality %", "desc": false }]
      }
    },
    {
      "id": 22,
      "title": "Stale Data Detection",
      "type": "stat",
