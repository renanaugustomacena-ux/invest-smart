{
  "uid": "moneymaker-trading",
  "title": "MONEYMAKER V1 - Trading Performance",
  "description": "Trading signals, execution, and strategy performance metrics for the MONEYMAKER autonomous trading ecosystem",
  "tags": ["moneymaker", "trading"],
  "timezone": "utc",
  "editable": true,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "15s", "30s", "1m", "5m"]
  },
  "links": [
    {
      "title": "MONEYMAKER - System Overview",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/moneymaker-overview/moneymaker-v1-system-overview",
      "tooltip": "Navigate to System Overview dashboard",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": false
    },
    {
      "title": "MONEYMAKER - Risk Management",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/moneymaker-risk/moneymaker-v1-risk-management",
      "tooltip": "Navigate to Risk Management dashboard",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": false
    },
    {
      "title": "MONEYMAKER - Data Ingestion",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/moneymaker-data/moneymaker-v1-data-ingestion",
      "tooltip": "Navigate to Data Ingestion dashboard",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": false
    }
  ],
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "strategy",
        "label": "Strategy",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(moneymaker_brain_strategy_signals_total, strategy)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "type": "query",
        "name": "symbol",
        "label": "Symbol",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(moneymaker_brain_signals_generated_total, symbol)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "type": "custom",
        "name": "direction",
        "label": "Direction",
        "query": "LONG,SHORT,FLAT",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "LONG", "value": "LONG" },
          { "selected": false, "text": "SHORT", "value": "SHORT" },
          { "selected": false, "text": "FLAT", "value": "FLAT" }
        ]
      },
      {
        "type": "interval",
        "name": "interval",
        "label": "Interval",
        "auto": true,
        "auto_count": 30,
        "auto_min": "10s",
        "query": "30s,1m,5m,15m,1h",
        "options": [
          { "selected": false, "text": "30s", "value": "30s" },
          { "selected": false, "text": "1m", "value": "1m" },
          { "selected": true, "text": "5m", "value": "5m" },
          { "selected": false, "text": "15m", "value": "15m" },
          { "selected": false, "text": "1h", "value": "1h" }
        ],
        "current": { "selected": true, "text": "5m", "value": "5m" }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(255, 96, 96, 1)",
        "expr": "changes(moneymaker_service_build_info[1m]) > 0",
        "step": "60s",
        "titleFormat": "Deployment",
        "textFormat": "Service {{service}} deployed version {{version}}",
        "tagKeys": "service",
        "useValueForTime": false,
        "type": "tags"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "TRADING KPIs",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "panels": []
    },
    {
      "id": 2,
      "title": "Signals Generated",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(moneymaker_brain_signals_generated_total[6h]))",
          "legendFormat": "Generated",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "blue" }]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 3,
      "title": "Signals Rejected",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(moneymaker_brain_signals_rejected_total[6h]))",
          "legendFormat": "Rejected",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 20, "color": "yellow" },
              { "value": 50, "color": "red" }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 4,
      "title": "Orders Filled",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(moneymaker_mt5_orders_filled_total[6h]))",
          "legendFormat": "Filled",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "green" }]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 5,
      "title": "Unrealized P&L",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "moneymaker_mt5_unrealized_pnl",
          "legendFormat": "Unrealized P&L",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0, "color": "green" }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 6,
      "title": "Open Positions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "moneymaker_mt5_open_positions",
          "legendFormat": "Open",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" },
              { "value": 5, "color": "yellow" },
              { "value": 10, "color": "red" }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 7,
      "title": "Slippage p95",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(moneymaker_bridge_slippage_pips_bucket[5m])) by (le))",
          "legendFormat": "p95 slippage",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 2, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          },
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 8,
      "title": "SIGNAL FLOW",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "panels": []
    },
    {
      "id": 9,
      "title": "Signals Generated vs Rejected",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_brain_signals_generated_total{symbol=~\"$symbol\"}[$interval]))",
          "legendFormat": "Generated",
          "refId": "A"
        },
        {
          "expr": "sum(rate(moneymaker_brain_signals_rejected_total{symbol=~\"$symbol\"}[$interval]))",
          "legendFormat": "Rejected",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Generated" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Rejected" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "sum"] }
      }
    },
    {
      "id": 10,
      "title": "Signal Confidence Distribution",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(moneymaker_brain_signal_confidence_bucket[5m])) by (le))",
          "legendFormat": "p50 confidence",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.75, sum(rate(moneymaker_brain_signal_confidence_bucket[5m])) by (le))",
          "legendFormat": "p75 confidence",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(moneymaker_brain_signal_confidence_bucket[5m])) by (le))",
          "legendFormat": "p90 confidence",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(moneymaker_brain_signal_confidence_bucket[5m])) by (le))",
          "legendFormat": "p99 confidence",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }
      }
    },
    {
      "id": 11,
      "title": "Orders Submitted vs Filled",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_mt5_orders_submitted_total[$interval]))",
          "legendFormat": "Submitted",
          "refId": "A"
        },
        {
          "expr": "sum(rate(moneymaker_mt5_orders_filled_total[$interval]))",
          "legendFormat": "Filled",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Submitted" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Filled" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "sum"] }
      }
    },
    {
      "id": 12,
      "title": "Signals by Strategy & Direction",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_brain_strategy_signals_total{strategy=~\"$strategy\",direction=~\"$direction\"}[$interval])) by (strategy, direction)",
          "legendFormat": "{{strategy}} ({{direction}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      }
    },
    {
      "id": 13,
      "title": "STRATEGY PERFORMANCE",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "panels": []
    },
    {
      "id": 14,
      "title": "P&L by Strategy",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "moneymaker_brain_strategy_profit{strategy=~\"$strategy\"}",
          "legendFormat": "{{strategy}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "axisCenteredZero": true
          },
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0, "color": "green" }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "always",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 15,
      "title": "Win Rate by Strategy",
      "type": "stat",
      "gridPos": { "h": 10, "w": 8, "x": 8, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(sum(moneymaker_brain_strategy_wins{strategy=~\"$strategy\"}) by (strategy) / (sum(moneymaker_brain_strategy_wins{strategy=~\"$strategy\"}) by (strategy) + sum(moneymaker_brain_strategy_losses{strategy=~\"$strategy\"}) by (strategy))) * 100",
          "legendFormat": "{{strategy}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 40, "color": "orange" },
              { "value": 50, "color": "yellow" },
              { "value": 60, "color": "green" }
            ]
          },
          "decimals": 1,
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal"
      }
    },
    {
      "id": 16,
      "title": "Strategy Comparison Matrix",
      "type": "table",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "moneymaker_brain_strategy_profit{strategy=~\"$strategy\"}",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "(sum(moneymaker_brain_strategy_wins{strategy=~\"$strategy\"}) by (strategy) / (sum(moneymaker_brain_strategy_wins{strategy=~\"$strategy\"}) by (strategy) + sum(moneymaker_brain_strategy_losses{strategy=~\"$strategy\"}) by (strategy))) * 100",
          "legendFormat": "",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "moneymaker_brain_sharpe_ratio{strategy=~\"$strategy\"}",
          "legendFormat": "",
          "refId": "C",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "indexByName": { "strategy": 0, "Value #A": 1, "Value #B": 2, "Value #C": 3 },
            "renameByName": {
              "strategy": "Strategy",
              "Value #A": "P&L ($)",
              "Value #B": "Win Rate (%)",
              "Value #C": "Sharpe Ratio"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P&L ($)" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 0, "color": "green" }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Win Rate (%)" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 50, "color": "yellow" }, { "value": 60, "color": "green" }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Sharpe Ratio" },
            "properties": [
              { "id": "decimals", "value": 2 },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "yellow" }, { "value": 2, "color": "green" }] } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false, "reducer": ["sum"], "countRows": false },
        "sortBy": [{ "displayName": "P&L ($)", "desc": true }]
      }
    },
    {
      "id": 17,
      "title": "Regime Distribution",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(moneymaker_brain_regime_classified_total[6h])) by (regime)",
          "legendFormat": "{{regime}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
