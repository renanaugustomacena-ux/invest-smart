{
  "uid": "moneymaker-risk",
  "title": "MONEYMAKER V1 - Risk Management",
  "description": "Risk metrics: daily loss, drawdown, positions, kill switch, and limits",
  "tags": ["moneymaker", "risk"],
  "timezone": "utc",
  "editable": true,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "15s", "30s", "1m", "5m"]
  },
  "links": [
    {
      "title": "MONEYMAKER - System Overview",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/moneymaker-overview/moneymaker-v1-system-overview",
      "tooltip": "Navigate to System Overview",
      "keepTime": true,
      "includeVars": true,
      "targetBlank": false
    },
    {
      "title": "MONEYMAKER - Trading",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/moneymaker-trading/moneymaker-v1-trading",
      "tooltip": "Navigate to Trading Dashboard",
      "keepTime": true,
      "includeVars": true,
      "targetBlank": false
    },
    {
      "title": "MONEYMAKER - Data Ingestion",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/moneymaker-data/moneymaker-v1-data-ingestion",
      "tooltip": "Navigate to Data Ingestion Dashboard",
      "keepTime": true,
      "includeVars": true,
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "symbol",
        "label": "Symbol",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(moneymaker_mt5_open_positions, symbol)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "type": "custom",
        "name": "risk_level",
        "label": "Risk Level",
        "query": "LOW,MEDIUM,HIGH,CRITICAL",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "LOW", "value": "LOW" },
          { "selected": false, "text": "MEDIUM", "value": "MEDIUM" },
          { "selected": false, "text": "HIGH", "value": "HIGH" },
          { "selected": false, "text": "CRITICAL", "value": "CRITICAL" }
        ]
      },
      {
        "type": "interval",
        "name": "interval",
        "label": "Interval",
        "auto": true,
        "auto_count": 30,
        "auto_min": "10s",
        "options": [
          { "selected": false, "text": "30s", "value": "30s" },
          { "selected": false, "text": "1m", "value": "1m" },
          { "selected": true, "text": "5m", "value": "5m" },
          { "selected": false, "text": "15m", "value": "15m" },
          { "selected": false, "text": "1h", "value": "1h" }
        ],
        "current": { "selected": true, "text": "5m", "value": "5m" }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "expr": "changes(moneymaker_service_build_info[1m]) > 0",
        "titleFormat": "Deployment",
        "textFormat": "Service deployed",
        "tagKeys": "service",
        "step": "60s",
        "type": "tags"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "RISK STATUS",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "title": "KILL SWITCH",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "moneymaker_brain_kill_switch_active",
          "legendFormat": "Kill Switch",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "INACTIVE - TRADING OK", "color": "green" },
                "1": { "text": "ACTIVE - ALL TRADING HALTED", "color": "red" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "text": { "titleSize": 20, "valueSize": 30 }
      }
    },
    {
      "id": 3,
      "title": "Daily Loss %",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "moneymaker_brain_daily_loss_pct",
          "legendFormat": "Daily Loss",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 10,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 2, "color": "yellow" },
              { "value": 4, "color": "orange" },
              { "value": 6, "color": "red" }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "title": "Drawdown %",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "moneymaker_brain_drawdown_pct",
          "legendFormat": "Drawdown",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 20,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 10, "color": "orange" },
              { "value": 15, "color": "red" }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },
    {
      "id": 5,
      "title": "Risk Score Composite",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - ((moneymaker_brain_daily_loss_pct / 10 * 25) + (moneymaker_brain_drawdown_pct / 20 * 25) + (moneymaker_mt5_open_positions / 20 * 25) + (clamp_max(sum(rate(moneymaker_brain_correlation_blocked_total[5m])) * 100, 1) * 25))",
          "legendFormat": "Risk Score",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 50, "color": "orange" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "green" }
            ]
          },
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "text": { "titleSize": 16, "valueSize": 40 }
      }
    },
    {
      "id": 6,
      "title": "Open Positions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "moneymaker_mt5_open_positions",
          "legendFormat": "Positions",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" },
              { "value": 5, "color": "yellow" },
              { "value": 10, "color": "orange" },
              { "value": 15, "color": "red" }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 7,
      "title": "Unrealized P&L",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "moneymaker_mt5_unrealized_pnl",
          "legendFormat": "P&L",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0, "color": "green" }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 8,
      "title": "Correlation Blocks (6h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(moneymaker_brain_correlation_blocked_total[6h]))",
          "legendFormat": "Blocked",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 20, "color": "red" }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 9,
      "title": "Rate Limit Hits (6h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(moneymaker_brain_rate_limit_hits_total[6h]))",
          "legendFormat": "Rate Limits",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 20, "color": "red" }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 10,
      "title": "RISK TRENDS",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "panels": []
    },
    {
      "id": 11,
      "title": "Daily Loss % Over Time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "moneymaker_brain_daily_loss_pct",
          "legendFormat": "Daily Loss %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "thresholdsStyle": { "mode": "area" }
          },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "transparent" },
              { "value": 2, "color": "rgba(255, 235, 59, 0.15)" },
              { "value": 4, "color": "rgba(255, 152, 0, 0.15)" },
              { "value": 6, "color": "rgba(244, 67, 54, 0.20)" }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Daily Loss %" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 12,
      "title": "Drawdown % Over Time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "moneymaker_brain_drawdown_pct",
          "legendFormat": "Drawdown %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "thresholdsStyle": { "mode": "area" }
          },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "transparent" },
              { "value": 5, "color": "rgba(255, 235, 59, 0.15)" },
              { "value": 10, "color": "rgba(255, 152, 0, 0.15)" },
              { "value": 15, "color": "rgba(244, 67, 54, 0.20)" }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Drawdown %" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 13,
      "title": "Unrealized P&L Over Time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "moneymaker_mt5_unrealized_pnl",
          "legendFormat": "Unrealized P&L",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": true,
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "min", "max", "lastNotNull"] }
      }
    },
    {
      "id": 14,
      "title": "Open Positions Over Time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "moneymaker_mt5_open_positions",
          "legendFormat": "Open Positions",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" },
              { "value": 5, "color": "yellow" },
              { "value": 10, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 15,
      "title": "CORRELATION & LIMITS",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "panels": []
    },
    {
      "id": 16,
      "title": "Correlation Blocks by Currency",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_brain_correlation_blocked_total[5m])) by (currency)",
          "legendFormat": "{{currency}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"] }
      }
    },
    {
      "id": 17,
      "title": "Rate Limit Hits Over Time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 8, "x": 8, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(moneymaker_brain_rate_limit_hits_total[5m])",
          "legendFormat": "Rate Limit Hits/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.1, "color": "yellow" },
              { "value": 0.5, "color": "red" }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Rate Limit Hits/s" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max", "sum"] }
      }
    },
    {
      "id": 18,
      "title": "Daily Loss vs Drawdown Correlation",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "moneymaker_brain_daily_loss_pct",
          "legendFormat": "Daily Loss %",
          "refId": "A"
        },
        {
          "expr": "moneymaker_brain_drawdown_pct",
          "legendFormat": "Drawdown %",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "axisPlacement": "auto"
          },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Daily Loss %" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Drawdown %" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 19,
      "title": "Position Concentration by Symbol",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 45 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(moneymaker_mt5_position_size{symbol=~\"$symbol\"}) by (symbol)",
          "legendFormat": "{{symbol}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
