{
  "uid": "moneymaker-overview",
  "title": "MONEYMAKER V1 - System Overview",
  "description": "System health overview for all MONEYMAKER services - command center, error analysis, processing, and alerts",
  "tags": ["moneymaker", "overview"],
  "timezone": "utc",
  "editable": true,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "15s", "30s", "1m", "5m"]
  },
  "links": [
    {
      "title": "MONEYMAKER Trading",
      "type": "link",
      "icon": "bolt",
      "url": "/d/moneymaker-trading/moneymaker-v1-trading-performance",
      "tooltip": "Trading signals, execution, and strategy performance",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": true
    },
    {
      "title": "MONEYMAKER Risk",
      "type": "link",
      "icon": "shield",
      "url": "/d/moneymaker-risk/moneymaker-v1-risk-management",
      "tooltip": "Risk metrics: daily loss, drawdown, positions, kill switch",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": true
    },
    {
      "title": "MONEYMAKER Data",
      "type": "link",
      "icon": "database",
      "url": "/d/moneymaker-data/moneymaker-v1-data-pipeline",
      "tooltip": "Data ingestion monitoring: ticks, bars, quality, latency",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": true
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 0,
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Deployments",
        "type": "tags",
        "expr": "moneymaker_deployment_timestamp",
        "step": "1m",
        "tagKeys": "service,version",
        "titleFormat": "Deploy: {{service}} v{{version}}",
        "textFormat": "Deployed {{service}} version {{version}}",
        "useValueForTime": true
      }
    ]
  },
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "symbol",
        "label": "Symbol",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(moneymaker_ingestion_ticks_received_total, symbol)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      },
      {
        "type": "query",
        "name": "service",
        "label": "Service",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(moneymaker_service_up, service)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      },
      {
        "type": "interval",
        "name": "interval",
        "label": "Interval",
        "auto": true,
        "auto_count": 30,
        "auto_min": "10s",
        "options": [
          { "selected": false, "text": "30s", "value": "30s" },
          { "selected": false, "text": "1m", "value": "1m" },
          { "selected": true, "text": "5m", "value": "5m" },
          { "selected": false, "text": "15m", "value": "15m" },
          { "selected": false, "text": "1h", "value": "1h" }
        ],
        "current": {
          "selected": true,
          "text": "5m",
          "value": "5m"
        },
        "query": "30s,1m,5m,15m,1h"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "COMMAND CENTER",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "Kill Switch Status",
      "type": "stat",
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "moneymaker_brain_kill_switch_active",
          "legendFormat": "Kill Switch",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "INACTIVE", "color": "green", "index": 0 },
                "1": { "text": "ACTIVE - HALTED", "color": "red", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      }
    },
    {
      "id": 3,
      "title": "Algo Engine Status",
      "type": "stat",
      "gridPos": { "h": 5, "w": 5, "x": 5, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "moneymaker_service_up{service=\"algo-engine\"}",
          "legendFormat": "Algo Engine",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "title": "MT5 Bridge Status",
      "type": "stat",
      "gridPos": { "h": 5, "w": 5, "x": 10, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "moneymaker_service_up{service=\"mt5_bridge\"}",
          "legendFormat": "MT5 Bridge",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      }
    },
    {
      "id": 5,
      "title": "Data Ingestion Status",
      "type": "stat",
      "gridPos": { "h": 5, "w": 5, "x": 15, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "moneymaker_service_up{service=\"data_ingestion\"}",
          "legendFormat": "Data Ingestion",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      }
    },
    {
      "id": 6,
      "title": "System Health Score",
      "type": "gauge",
      "gridPos": { "h": 10, "w": 4, "x": 20, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(sum(moneymaker_service_up) / count(moneymaker_service_up)) * 100 * (1 - clamp_max(sum(rate(moneymaker_errors_total[5m])) / 10, 1)) * (1 - clamp_max(histogram_quantile(0.95, sum(rate(moneymaker_brain_pipeline_latency_seconds_bucket[5m])) by (le)) / 1, 1))",
          "legendFormat": "Health Score",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 50, "color": "orange" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "green" }
            ]
          },
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },
    {
      "id": 7,
      "title": "Total Errors 24h",
      "type": "stat",
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 6 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(moneymaker_errors_total[24h]))",
          "legendFormat": "Errors",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 50, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto"
      }
    },
    {
      "id": 8,
      "title": "Pipeline Latency p95",
      "type": "stat",
      "gridPos": { "h": 5, "w": 5, "x": 5, "y": 6 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(moneymaker_brain_pipeline_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.1, "color": "yellow" },
              { "value": 0.5, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto"
      }
    },
    {
      "id": 9,
      "title": "Service Health Matrix",
      "type": "stat",
      "gridPos": { "h": 5, "w": 5, "x": 10, "y": 6 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "moneymaker_service_up{service=~\"$service\"}",
          "legendFormat": "{{service}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "dark-red", "index": 0 },
                "1": { "text": "UP", "color": "dark-green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          },
          "noValue": "NO DATA"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal"
      }
    },
    {
      "id": 10,
      "title": "Service Uptime 24h",
      "type": "stat",
      "gridPos": { "h": 5, "w": 5, "x": 15, "y": 6 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(avg_over_time(moneymaker_service_up{service=~\"$service\"}[24h]) * 100)",
          "legendFormat": "{{service}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 95, "color": "yellow" },
              { "value": 99, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal"
      }
    },
    {
      "id": 11,
      "title": "ERROR ANALYSIS",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 12,
      "title": "Error Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 13 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_errors_total[$interval])) by (service) * on(service) group_left() (moneymaker_service_up{service=~\"$service\"})",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "pointSize": 5,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "axisColorMode": "text"
          },
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.5, "color": "yellow" },
              { "value": 2, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 13,
      "title": "Error Rate by Type",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 13 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_errors_total[$interval])) by (error_type)",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "pointSize": 5,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "axisColorMode": "text"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 14,
      "title": "Pipeline Latency p50/p95/p99",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 15, "x": 0, "y": 23 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(moneymaker_brain_pipeline_latency_seconds_bucket[$interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(moneymaker_brain_pipeline_latency_seconds_bucket[$interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(moneymaker_brain_pipeline_latency_seconds_bucket[$interval])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "axisColorMode": "text"
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.1, "color": "yellow" },
              { "value": 0.5, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 15,
      "title": "Error vs Latency Correlation",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 9, "x": 15, "y": 23 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_errors_total[$interval]))",
          "legendFormat": "Error Rate (errors/s)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(moneymaker_brain_pipeline_latency_seconds_bucket[$interval])) by (le)) * 1000",
          "legendFormat": "Pipeline Latency p95 (ms)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 0,
            "pointSize": 5,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "axisPlacement": "auto"
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Error Rate (errors/s)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "left" },
              { "id": "unit", "value": "ops" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Pipeline Latency p95 (ms)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "ms" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 16,
      "title": "PROCESSING & FEATURES",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 17,
      "title": "Features Computed per Symbol",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 35 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(moneymaker_brain_features_computed_total{symbol=~\"$symbol\"}[$interval])) by (symbol)",
          "legendFormat": "{{symbol}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "axisColorMode": "text"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 18,
      "title": "Error Distribution Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 35 },
      "datasource": {
        "type": "prometheus",
