# ============================================================
# MONEYMAKER Certificate Directory - Git Ignore
# ============================================================
# SECURITY: Never commit private keys or certificates to the repository.
# These files contain sensitive cryptographic material.
# ============================================================

# Private keys - NEVER commit these
*.key
*.pem

# Certificates - exclude from repo (regenerate per environment)
*.crt
*.cert

# Certificate signing requests
*.csr

# OpenSSL serial file
*.srl

# OpenSSL config files (generated by script)
*-openssl.cnf

# macOS
.DS_Store

# Keep the script and this gitignore
!generate-certs.sh
!.gitignore
