# ============================================================
# MONEYMAKER V1 Environment Configuration
# ============================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Generate strong passwords for all *_PASSWORD variables
# 3. Fill in API keys from your providers
# 4. NEVER commit .env to version control
#
# SECURITY REQUIREMENTS:
# - All passwords must be at least 16 characters
# - Use randomly generated passwords (see command below)
# - Never use default values in production
#
# Generate a secure password:
#   Linux/Mac: openssl rand -base64 24
#   PowerShell: [Convert]::ToBase64String((1..24 | ForEach-Object { Get-Random -Maximum 256 }))
#
# ============================================================

# --- General ---
MONEYMAKER_ENV=development          # development | staging | production

# === DATABASE (REQUIRED) ===
MONEYMAKER_DB_HOST=localhost
MONEYMAKER_DB_PORT=5432
MONEYMAKER_DB_NAME=moneymaker
# Admin user for migrations and init scripts
MONEYMAKER_DB_USER=moneymaker
# REQUIRED: Generate with: openssl rand -base64 24
MONEYMAKER_DB_PASSWORD=

# === DATABASE RBAC (Optional - Enables Per-Service Users) ===
# When set, services use these credentials instead of MONEYMAKER_DB_*
# This enables least-privilege access control (recommended for production).
# Generate passwords with: openssl rand -base64 24

# Data Ingestion Service (writes market data only)
DI_DB_USER=data_ingestion_svc
DI_DB_PASSWORD=

# Algo Engine Service (reads market data, writes signals)
ALGO_DB_USER=algo_engine_svc
ALGO_DB_PASSWORD=

# MT5 Bridge Service (reads signals, writes executions)
MT5_DB_USER=mt5_bridge_svc
MT5_DB_PASSWORD=

# Admin Role (full access for maintenance, optional)
ADMIN_DB_PASSWORD=

# === REDIS (REQUIRED) ===
MONEYMAKER_REDIS_HOST=localhost
MONEYMAKER_REDIS_PORT=6379
# REQUIRED: Generate with: openssl rand -base64 24
MONEYMAKER_REDIS_PASSWORD=

# === MONITORING (REQUIRED) ===
GRAFANA_USER=admin
# REQUIRED: Generate with: openssl rand -base64 16
GRAFANA_PASSWORD=

# === ZeroMQ ===
MONEYMAKER_ZMQ_PUB_ADDR=tcp://localhost:5555

# === gRPC Ports ===
ALGO_GRPC_PORT=50057
MONEYMAKER_MT5_BRIDGE_GRPC_PORT=50055
MONEYMAKER_DATA_INGESTION_GRPC_PORT=50051

# === Algo Engine Service ===
ALGO_SERVICE_NAME=algo-engine
ALGO_REST_PORT=8087
ALGO_METRICS_PORT=9097
ALGO_ZMQ_DATA_FEED=tcp://localhost:5555
ALGO_CONFIDENCE_THRESHOLD=0.65
ALGO_MAX_SIGNALS_PER_HOUR=10
ALGO_MAX_OPEN_POSITIONS=5
ALGO_MAX_DAILY_LOSS_PCT=2.0
ALGO_MAX_DRAWDOWN_PCT=5.0
ALGO_DEFAULT_RSI_PERIOD=14
ALGO_DEFAULT_EMA_FAST=12
ALGO_DEFAULT_EMA_SLOW=26
ALGO_DEFAULT_BB_PERIOD=20
ALGO_DEFAULT_ATR_PERIOD=14

# === Data Ingestion Service ===
MONEYMAKER_METRICS_PORT=9090

# === MT5 Bridge Service ===
MONEYMAKER_MT5_BRIDGE_METRICS_PORT=9094
# REQUIRED for live trading:
MT5_ACCOUNT=
MT5_PASSWORD=
MT5_SERVER=
MT5_TIMEOUT_MS=10000
MAX_POSITION_COUNT=5
MAX_LOT_SIZE=1.0
MAX_DAILY_LOSS_PCT=2.0
MAX_DRAWDOWN_PCT=5.0
SIGNAL_DEDUP_WINDOW_SEC=60
SIGNAL_MAX_AGE_SEC=30
TRAILING_STOP_ENABLED=true
TRAILING_STOP_PIPS=50.0

# === Dashboard Service ===
DASHBOARD_PORT=8888

# === Data Ingestion Health Port (host-side mapping) ===
DATA_INGESTION_HEALTH_PORT=8081

# === Market Data API Keys ===
# Get from: https://polygon.io (REQUIRED for Forex data)
POLYGON_API_KEY=

# Optional: Binance for crypto data
MONEYMAKER_BINANCE_API_KEY=
MONEYMAKER_BINANCE_API_SECRET=

# Optional: Bybit for crypto data
MONEYMAKER_BYBIT_API_KEY=
MONEYMAKER_BYBIT_API_SECRET=

# Optional: FRED for macro data (improves rate limits)
# Get from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# === TLS Configuration ===
# Enable TLS for encrypted connections to PostgreSQL, Redis, and gRPC.
# Set to 'true' in staging/production for secure communications.
# IMPORTANT: Generate certificates first with: infra/certs/generate-certs.sh
MONEYMAKER_TLS_ENABLED=false

# Path to CA certificate (inside containers)
MONEYMAKER_TLS_CA_CERT=/etc/ssl/certs/ca.crt

# mTLS: Client certificates for gRPC inter-service authentication
# Each service uses its own certificate for identity verification
# These paths are set per-service in docker-compose.yml
# MONEYMAKER_TLS_CLIENT_CERT=/etc/ssl/certs/<service-name>.crt
# MONEYMAKER_TLS_CLIENT_KEY=/etc/ssl/private/<service-name>.key

# mTLS: Server certificates for gRPC servers (MT5 Bridge, ML Training)
# MONEYMAKER_TLS_SERVER_CERT=/etc/ssl/certs/<service-name>.crt
# MONEYMAKER_TLS_SERVER_KEY=/etc/ssl/private/<service-name>.key

# === Rate Limiting (Protezione DoS) ===
# Abilita rate limiting per proteggere da abusi e sovraccarichi.
# Usa Redis per rate limiting distribuito tra istanze.
# Se Redis non è raggiungibile, usa rate limiting in-memory (locale).

# MT5 Bridge: Limita le richieste di trading
# RATE_LIMIT_ENABLED=true               # Abilita/disabilita rate limiting
# RATE_LIMIT_REQUESTS_PER_MINUTE=10     # Max richieste trade al minuto
# RATE_LIMIT_BURST_SIZE=5               # Capacità extra per burst
